NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Enables admin-side signup, invites, and invited-user linking.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for the self-serve /api/signup flow.
DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000000

# Preferred base URL for invite links outside Vercel previews.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enables AI-assisted API routes.
OPENAI_API_KEY=

# Enables outbound email delivery for record PDFs.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
